# Copy this file to .env and fill in the API keys you actually use.

# Provider secrets
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Provider default models
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
GOOGLE_DEFAULT_MODEL=gemini-3-flash-preview
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# Single-agent baseline
SINGLE_AGENT_PROVIDER=google
SINGLE_AGENT_MODEL=
SINGLE_AGENT_TIMEOUT_SECONDS=75
SINGLE_AGENT_MAX_ATTEMPTS=3
SINGLE_AGENT_BACKOFF_BASE_SECONDS=2
SINGLE_AGENT_BACKOFF_CAP_SECONDS=20
SINGLE_AGENT_THINKING_LEVEL=low

# Future multi-agent roles
PLANNER_PROVIDER=google
PLANNER_MODEL=
PLANNER_TIMEOUT_SECONDS=75
PLANNER_THINKING_LEVEL=low

REVIEWER_PROVIDER=anthropic
REVIEWER_MODEL=
REVIEWER_TIMEOUT_SECONDS=60

JUDGE_PROVIDER=openai
JUDGE_MODEL=
JUDGE_TIMEOUT_SECONDS=60

TRIAGE_PROVIDER=google
TRIAGE_MODEL=
TRIAGE_TIMEOUT_SECONDS=45
TRIAGE_THINKING_LEVEL=low

MULTI_AGENT_MAX_TURNS=3

# Legacy compatibility knobs still read by the single-agent worker
GEMINI_MODEL=
GEMINI_PLANNER_TIMEOUT_SECONDS=
GEMINI_PLANNER_MAX_ATTEMPTS=
GEMINI_PLANNER_BACKOFF_BASE_SECONDS=
GEMINI_PLANNER_BACKOFF_CAP_SECONDS=
GEMINI_THINKING_LEVEL=

# Runtime checks
COMMAND_TIMEOUT_SECONDS=20
HTTP_TIMEOUT_SECONDS=3
POSTCHECK_RETRY_ATTEMPTS=15
POSTCHECK_RETRY_INTERVAL_SECONDS=2
